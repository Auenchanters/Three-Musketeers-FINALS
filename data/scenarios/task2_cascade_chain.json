  "commits": [
    {"hash": "commit-bat100", "service": "batch", "timestamp": "2026-04-17T08:44:00Z", "author": "frank@company.com", "message": "feat: add permissions pre-computation pipeline — processes all user org permissions on startup for faster auth lookups", "diff": "--- a/batch-service/permissions/precompute.go\n+++ b/batch-service/permissions/precompute.go\n+func PrecomputePermissions(ctx context.Context) error {\n+    users, _ := db.GetAllUsers(ctx) // ~50,000 records\n+    for _, user := range users {\n+        orgs, _ := db.GetUserOrgs(ctx, user.ID)\n+        for _, org := range orgs {\n+            perms := computeOrgPermissions(org) // loads entire org tree into memory\n+            cache.Set(fmt.Sprintf(\"perms:%s:%s\", user.ID, org.ID), perms)\n+        }\n+    }\n+    return nil\n+}\n+\n+func init() {\n+    go PrecomputePermissions(context.Background()) // auto-start on boot\n+}", "relevant": true},
    {"hash": "commit-dat100", "service": "data", "timestamp": "2026-04-17T08:29:00Z", "author": "alice@company.com", "message": "refactor: reorganize batch integration layer to use new permissions endpoint", "diff": "--- a/data-service/integrations/batch.go\n+++ b/data-service/integrations/batch.go\n-endpoint := \"/internal/batch/compute\"\n+endpoint := \"/internal/batch/permissions\"\n+timeout := 5 * time.Second", "relevant": false},
    {"hash": "commit-auth100", "service": "auth", "timestamp": "2026-04-17T08:00:00Z", "author": "carol@company.com", "message": "feat: switch session storage to Redis Cluster", "diff": "--- a/auth-service/sessions/store.go\n+++ b/auth-service/sessions/store.go\n-store := redis.NewClient(opts)\n+store := redis.NewClusterClient(clusterOpts)", "relevant": false},
    {"hash": "commit-auth101", "service": "auth", "timestamp": "2026-04-17T09:09:00Z", "author": "carol@company.com", "message": "feat: add permission caching with 30-min TTL", "diff": "--- a/auth-service/permissions/cache.go\n+++ b/auth-service/permissions/cache.go\n+func CachePermissions(userID string, perms []Permission) {\n+    cache.SetWithTTL(\"perms:\"+userID, perms, 30*time.Minute)\n+}", "relevant": false},
